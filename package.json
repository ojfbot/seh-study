{
  "name": "seh-study",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev:all": "concurrently -n api,app -c blue,green \"pnpm --filter @ojfbot/seh-study-api dev\" \"pnpm --filter @ojfbot/seh-study-browser-app dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "generate-scenarios": "tsx scripts/generate-scenarios.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
